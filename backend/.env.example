# Backend Environment Variables
# Copy this file to .env and fill in actual values

# Server
PORT=4000
NODE_ENV=development

# PostgreSQL (Main Application Database)
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=attendease
PG_USER=postgres
PG_PASSWORD=your_pg_password_here

# MS SQL (Biometric eSSL Device Database)
MSSQL_HOST=localhost
MSSQL_PORT=1433
MSSQL_DATABASE=eSSL_DB
MSSQL_USER=sa
MSSQL_PASSWORD=your_mssql_password_here

# JWT Configuration
JWT_SECRET=change_this_to_a_strong_random_secret_in_production
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=change_this_to_another_strong_random_secret
JWT_REFRESH_EXPIRES_IN=7d

# Biometric Device
BIOMETRIC_DEVICE_SERIAL=JJA1244600336
BIOMETRIC_SYNC_INTERVAL_MINUTES=5

# Frontend URL (for CORS) — comma-separated for multiple origins, or * to allow all
CORS_ORIGINS=http://localhost:3000

# Email SMTP (Mailgun / any SMTP provider)
EMAIL_FROM=no-reply@nationalgroupindia.com
EMAIL_LOGIN=
EMAIL_PASSWORD=
EMAIL_PORT=587
EMAIL_SERVER=smtp.mailgun.org

# Logging
LOG_LEVEL=info
